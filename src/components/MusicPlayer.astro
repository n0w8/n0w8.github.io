---
// Artist-Backlink + Musik-Embed. Erscheint in Artikeln als "Soundtrack zum Kapitel".
// Der Spotify-Artist-Embed spielt die Top-Tracks (= diverse Songs) direkt ab.
import { artists, type ArtistKey } from '../data/artists';
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/ui';

interface Props {
  artistKey: ArtistKey;
  lang: Lang;
  label?: string;
}
const { artistKey, lang, label } = Astro.props;
const artist = artists[artistKey];
const t = useTranslations(lang);
---

<aside class="music-player" aria-label={`${t('article.soundtrack')}: ${artist.name}`}>
  <div class="mp-head">
    <span class="mp-rune" aria-hidden="true">♬</span>
    <div>
      <p class="mp-eyebrow">{t('article.soundtrack')}</p>
      <p class="mp-title">{label ?? artist.name}</p>
    </div>
  </div>

  <div class="mp-embed">
    <iframe
      src={artist.spotifyEmbed}
      title={`Spotify: ${artist.name}`}
      loading="lazy"
      frameborder="0"
      allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
      allowfullscreen
    ></iframe>
  </div>

  <div class="mp-links">
    <a href={artist.spotifyUrl} target="_blank" rel="noopener" class="mp-link mp-link--spotify">
      ▶ {artist.name} {t('artists.spotify')}
    </a>
    <a href={artist.youtubeUrl} target="_blank" rel="noopener" class="mp-link mp-link--youtube">
      ▶ {t('artists.youtube')}
    </a>
  </div>
</aside>

<style>
  .music-player {
    margin: 2.5rem 0;
    padding: 1.4rem;
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius);
    background: linear-gradient(180deg, rgba(160, 44, 28, 0.06), transparent), var(--color-bg-raised);
    box-shadow: var(--shadow);
    position: relative;
  }
  .mp-head { display: flex; align-items: center; gap: 0.9rem; margin-bottom: 1rem; }
  .mp-rune {
    font-size: 1.6rem;
    color: var(--color-bronze);
    width: 44px; height: 44px;
    display: grid; place-items: center;
    border: 1px solid var(--color-border-strong);
    border-radius: 50%;
    flex-shrink: 0;
  }
  .mp-eyebrow {
    font-family: var(--font-title);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-size: 0.7rem;
    color: var(--color-bronze);
    margin: 0;
  }
  .mp-title { font-family: var(--font-title); color: var(--color-parchment); font-size: 1.1rem; margin: 0.15rem 0 0; }
  .mp-embed { border-radius: var(--radius); overflow: hidden; }
  .mp-embed iframe { height: 152px; width: 100%; }
  .mp-links { display: flex; flex-wrap: wrap; gap: 0.7rem; margin-top: 1rem; }
  .mp-link {
    font-family: var(--font-title);
    font-size: 0.85rem;
    padding: 0.5rem 1rem;
    border-radius: 999px;
    border: 1px solid var(--color-border-strong);
    color: var(--color-parchment);
    transition: all 0.2s ease;
  }
  .mp-link--spotify:hover { border-color: #1db954; color: #1db954; }
  .mp-link--youtube:hover { border-color: #ff0000; color: #ff4d4d; }
</style>
