---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../ArticleCard.astro';
import { artists } from '../../data/artists';
import { useTranslations, localizedPath, getPostsByLang, postUrl } from '../../i18n/utils';
import type { Lang } from '../../i18n/ui';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);

const posts = await getPostsByLang(lang);
const featured = posts[0];
const rest = posts.slice(1, 7);

const paths = [
  { name: 'Geschichte', key: 'Geschichte', icon: 'M12 2 L21 7 V17 L12 22 L3 17 V7 Z',
    desc: { de: 'Raubzüge, Könige und das Zeitalter der Nordmänner', en: 'Raids, kings and the age of the Northmen' } },
  { name: 'Mythologie', key: 'Mythologie', icon: 'M12 2 L12 22 M4 8 L20 8 M6 15 L18 15',
    desc: { de: 'Odin, Thor und die neun Welten von Yggdrasil', en: 'Odin, Thor and the nine worlds of Yggdrasil' } },
  { name: 'Runen', key: 'Runen', icon: 'M12 2 L12 22 M12 6 L18 12 M12 12 L18 6',
    desc: { de: 'Das Futhark und die verborgene Sprache des Nordens', en: 'The Futhark and the hidden language of the North' } },
  { name: 'Krieger', key: 'Krieger', icon: 'M12 2 L14 9 L21 9 L15 13 L17 21 L12 16 L7 21 L9 13 L3 9 L10 9 Z',
    desc: { de: 'Berserker, Waffen und die Kunst des Kampfes', en: 'Berserkers, weapons and the art of war' } },
];
const pathTitle: Record<string, { de: string; en: string }> = {
  Geschichte: { de: 'Geschichte', en: 'History' },
  Mythologie: { de: 'Mythologie', en: 'Mythology' },
  Runen: { de: 'Runen & Symbole', en: 'Runes & Symbols' },
  Krieger: { de: 'Krieger & Schlachten', en: 'Warriors & Battles' },
};
const artistList = [artists.domsgard, artists.eldruna];
---

<BaseLayout title="Nordweg" description={t('hero.lede')} lang={lang} altUrl={localizedPath('/', lang === 'de' ? 'en' : 'de')}>
  <section class="hero">
    <img class="hero-bg" src="/images/hero.jpg" alt="" aria-hidden="true" />
    <div class="hero-vignette" aria-hidden="true"></div>
    <div class="hero-fog" aria-hidden="true"></div>
    <div class="hero-aurora" aria-hidden="true"></div>
    <div class="hero-rune-mark" aria-hidden="true">ᛟ</div>
    <div class="container hero-inner">
      <p class="eyebrow hero-eyebrow">{t('hero.eyebrow')}</p>
      <h1 class="hero-title glow-text" set:html={t('hero.title')}></h1>
      <p class="hero-lede">{t('hero.lede')}</p>
      <div class="hero-actions">
        <a href={localizedPath('/blog', lang)} class="btn btn--primary">{t('hero.cta.explore')}</a>
        <a href={localizedPath('/artists', lang)} class="btn">{t('hero.cta.music')}</a>
      </div>
    </div>
    <div class="hero-runes" aria-hidden="true">ᚠ ᚢ ᚦ ᚨ ᚱ ᚲ ᚷ ᚹ ᚺ ᚾ</div>
    <a href="#discover" class="hero-scroll" aria-label="Scroll down">
      <span class="hero-scroll-line"></span>
    </a>
  </section>

  <section id="discover" class="container section reveal">
    <div class="section-head center">
      <p class="eyebrow flourish">{t('home.paths.eyebrow')}</p>
      <h2 class="section-title">{t('home.paths.title')}</h2>
    </div>
    <div class="cat-grid">
      {paths.map((cat) => (
        <a href={`${localizedPath('/blog', lang)}?cat=${encodeURIComponent(cat.key)}`} class="cat-card">
          <span class="cat-glow" aria-hidden="true"></span>
          <span class="cat-icon">
            <svg viewBox="0 0 24 24" width="34" height="34" aria-hidden="true">
              <path d={cat.icon} fill="none" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/>
            </svg>
          </span>
          <h3>{pathTitle[cat.key][lang]}</h3>
          <p class="text-dim">{cat.desc[lang]}</p>
          <span class="cat-enter" aria-hidden="true">ᛉ</span>
        </a>
      ))}
    </div>
  </section>

  <section class="container section reveal">
    <div class="section-head">
      <div>
        <p class="eyebrow flourish">{t('home.latest.eyebrow')}</p>
        <h2 class="section-title">{t('home.latest.title')}</h2>
      </div>
      <a href={localizedPath('/blog', lang)} class="section-link">{t('home.latest.all')}</a>
    </div>
    <div class="post-grid">
      {featured && (
        <ArticleCard href={postUrl(featured, lang)} title={featured.data.title} description={featured.data.description}
          category={featured.data.category} pubDate={featured.data.pubDate} lang={lang}
          heroImage={featured.data.heroImage} readingTime={featured.data.readingTime} featured={true} />
      )}
      {rest.map((post) => (
        <ArticleCard href={postUrl(post, lang)} title={post.data.title} description={post.data.description}
          category={post.data.category} pubDate={post.data.pubDate} lang={lang}
          heroImage={post.data.heroImage} readingTime={post.data.readingTime} />
      ))}
    </div>
  </section>

  <section class="container section reveal">
    <div class="section-head center">
      <p class="eyebrow flourish">{t('home.artists.eyebrow')}</p>
      <h2 class="section-title">{t('home.artists.title')}</h2>
      <p class="text-dim artists-lede">{t('home.artists.lede')}</p>
    </div>
    <div class="artist-grid">
      {artistList.map((a) => (
        <div class="artist-card">
          <div class="artist-info">
            <h3>{a.name}</h3>
            <p class="text-dim">{a.tagline[lang]}</p>
            <div class="artist-links">
              <a href={a.spotifyUrl} target="_blank" rel="noopener" class="btn">Spotify</a>
              <a href={a.youtubeUrl} target="_blank" rel="noopener" class="btn">YouTube</a>
            </div>
          </div>
          <iframe src={a.spotifyEmbed} title={`Spotify: ${a.name}`} loading="lazy" frameborder="0"
            allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" allowfullscreen></iframe>
        </div>
      ))}
    </div>
  </section>

  <section class="container section reveal">
    <div class="newsletter">
      <div class="newsletter-runes" aria-hidden="true">ᚹ</div>
      <div class="newsletter-glow" aria-hidden="true"></div>
      <p class="eyebrow flourish">{t('newsletter.eyebrow')}</p>
      <h2>{t('newsletter.title')}</h2>
      <p class="text-dim newsletter-copy">{t('newsletter.copy')}</p>
      <form class="newsletter-form" onsubmit="event.preventDefault(); this.querySelector('.nl-done').hidden=false; this.querySelector('input').value='';">
        <input type="email" placeholder={t('newsletter.placeholder')} required aria-label="E-Mail" />
        <button type="submit" class="btn btn--primary">{t('newsletter.button')}</button>
      </form>
      <p class="nl-done text-dim" hidden>{t('newsletter.done')}</p>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===== HERO — cinematic, carved from stone and firelight ===== */
  .hero { position: relative; overflow: hidden; padding: clamp(7rem, 20vh, 13rem) 0 clamp(6rem, 14vh, 9rem); text-align: center; border-bottom: 1px solid var(--color-border); min-height: clamp(560px, 88vh, 900px); display: flex; align-items: center; }
  .hero-bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.42; filter: saturate(0.85) contrast(1.1) brightness(0.92); transform: scale(1.06); transform-origin: 50% 45%; animation: heroKen 32s ease-in-out infinite alternate; will-change: transform; }
  @keyframes heroKen { from { transform: scale(1.06) translate3d(0, 0, 0); } to { transform: scale(1.16) translate3d(-1.5%, -2%, 0); } }

  /* deep edge vignette to draw the eye inward */
  .hero-vignette { position: absolute; inset: 0; pointer-events: none; background: radial-gradient(ellipse 90% 80% at 50% 42%, transparent 38%, rgba(8,7,5,0.55) 78%, rgba(8,7,5,0.9) 100%); }
  /* moodier layered fog: darker top+bottom, a smoulder of blood glow rising from below */
  .hero-fog { position: absolute; inset: 0; pointer-events: none; background:
      linear-gradient(180deg, rgba(12,10,8,0.72) 0%, rgba(16,13,10,0.42) 32%, rgba(16,13,10,0.58) 66%, var(--color-bg) 100%),
      radial-gradient(ellipse 75% 55% at 50% 100%, var(--glow-blood, rgba(160,44,28,0.28)), transparent 60%),
      radial-gradient(ellipse 70% 60% at 50% 0%, rgba(160,44,28,0.14), transparent 65%); }
  /* faint teal aurora drifting overhead */
  .hero-aurora { position: absolute; inset: -20% -10% auto -10%; height: 70%; pointer-events: none; opacity: 0.5; background: radial-gradient(ellipse 60% 50% at 30% 20%, var(--color-aurora, rgba(64,148,140,0.16)), transparent 60%), radial-gradient(ellipse 50% 45% at 75% 10%, var(--color-aurora, rgba(64,148,140,0.12)), transparent 60%); mix-blend-mode: screen; animation: auroraDrift 26s ease-in-out infinite alternate; }
  @keyframes auroraDrift { from { transform: translate3d(-3%, 0, 0) scale(1); opacity: 0.35; } to { transform: translate3d(4%, 2%, 0) scale(1.08); opacity: 0.6; } }

  /* huge faint rune watermark behind the title */
  .hero-rune-mark { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -54%); font-family: var(--font-display, serif); font-size: clamp(20rem, 46vw, 40rem); line-height: 1; color: var(--color-bronze); opacity: 0.045; pointer-events: none; user-select: none; text-shadow: 0 0 80px rgba(201,162,90,0.15); }

  .hero-inner { position: relative; z-index: 2; max-width: 820px; }
  .hero-eyebrow { display: block; margin-bottom: 1.4rem; text-shadow: 0 0 16px rgba(201,162,90,0.25); }
  .hero-title { font-size: clamp(2.8rem, 8.5vw, 5.4rem); line-height: 1.04; margin: 0 0 1.6rem; background: linear-gradient(175deg, var(--color-parchment) 8%, var(--color-bronze-bright, #e6c988) 46%, var(--color-bronze) 78%, #8a6a34 100%); -webkit-background-clip: text; background-clip: text; color: transparent; filter: drop-shadow(0 2px 3px rgba(0,0,0,0.6)) drop-shadow(0 0 24px var(--glow-bronze, rgba(201,162,90,0.28))); }
  .hero-title.glow-text { text-shadow: none; }
  .hero-lede { font-size: 1.22rem; line-height: 1.75; color: var(--color-text); max-width: 58ch; margin: 0 auto 2.4rem; text-shadow: 0 1px 12px rgba(0,0,0,0.6); }
  .hero-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
  .hero-runes { position: absolute; left: 0; right: 0; bottom: clamp(4.5rem, 9vh, 6.5rem); z-index: 2; font-size: 1.4rem; letter-spacing: 0.85em; color: var(--color-bronze); opacity: 0.28; text-shadow: 0 0 20px rgba(201,162,90,0.2); }

  /* elegant animated scroll cue */
  .hero-scroll { position: absolute; left: 50%; bottom: clamp(1.6rem, 4vh, 2.6rem); z-index: 3; transform: translateX(-50%); width: 26px; height: 44px; border: 1px solid var(--color-bronze-dim, rgba(201,162,90,0.5)); border-radius: 14px; display: flex; justify-content: center; padding-top: 8px; box-shadow: 0 0 20px var(--glow-bronze, rgba(201,162,90,0.18)) inset; transition: border-color 0.25s ease, box-shadow 0.25s ease; }
  .hero-scroll:hover { border-color: var(--color-bronze-bright, #e6c988); box-shadow: 0 0 24px var(--glow-bronze, rgba(201,162,90,0.35)) inset; }
  .hero-scroll-line { width: 2px; height: 8px; border-radius: 2px; background: var(--color-bronze-bright, #e6c988); animation: scrollCue 1.9s ease-in-out infinite; }
  @keyframes scrollCue { 0% { transform: translateY(0); opacity: 0; } 25% { opacity: 1; } 60% { transform: translateY(14px); opacity: 0; } 100% { opacity: 0; } }

  /* ===== SECTIONS ===== */
  .section { padding: clamp(3.5rem, 9vh, 6rem) 1.5rem; }
  .section-head { display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 2.6rem; gap: 1rem; }
  .section-head.center { flex-direction: column; align-items: center; text-align: center; }
  .section-title { font-size: clamp(1.8rem, 4vw, 2.6rem); margin: 0.4rem 0 0; }
  .section-link { font-family: var(--font-title); color: var(--color-bronze); white-space: nowrap; transition: color 0.2s ease, text-shadow 0.2s ease; }
  .section-link:hover { color: var(--color-bronze-bright, #e6c988); text-shadow: 0 0 14px var(--glow-bronze, rgba(201,162,90,0.4)); }
  .artists-lede { max-width: 54ch; margin: 1rem auto 0; }

  /* hairline rune flourish on eyebrows */
  .eyebrow.flourish { position: relative; }
  .section-head.center .eyebrow.flourish::before,
  .section-head.center .eyebrow.flourish::after { content: "ᛝ"; position: absolute; top: 50%; transform: translateY(-50%); font-size: 0.7em; color: var(--color-bronze); opacity: 0.55; }
  .section-head.center .eyebrow.flourish::before { right: calc(100% + 0.9rem); }
  .section-head.center .eyebrow.flourish::after { left: calc(100% + 0.9rem); }
  /* left-aligned heads: single leading hairline */
  .section-head:not(.center) .eyebrow.flourish { padding-left: 1.9rem; }
  .section-head:not(.center) .eyebrow.flourish::before { content: ""; position: absolute; left: 0; top: 50%; width: 1.3rem; height: 1px; background: linear-gradient(90deg, transparent, var(--color-bronze)); }

  /* ===== CATEGORY CARDS — mysterious portals ===== */
  .cat-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.2rem; }
  .cat-card { position: relative; overflow: hidden; isolation: isolate; border: 1px solid var(--color-border); border-radius: var(--radius); padding: 1.8rem 1.4rem; background:
      radial-gradient(ellipse 120% 90% at 50% -10%, rgba(201,162,90,0.05), transparent 60%),
      linear-gradient(180deg, var(--color-bg-raised), var(--color-ink, #0c0a08)); color: inherit; transition: transform 0.28s ease, border-color 0.28s ease, box-shadow 0.28s ease; }
  /* rune motif watermark inside each portal */
  .cat-card::after { content: "ᛜ"; position: absolute; right: -0.4rem; bottom: -1.2rem; font-family: var(--font-display, serif); font-size: 6rem; line-height: 1; color: var(--color-bronze); opacity: 0.05; pointer-events: none; transition: opacity 0.28s ease, transform 0.28s ease; }
  /* thin gradient border-glow ring on hover */
  .cat-glow { position: absolute; inset: 0; border-radius: var(--radius); padding: 1px; background: linear-gradient(140deg, var(--color-bronze-bright, #e6c988), transparent 40%, transparent 60%, var(--color-blood, #a02c1c)); -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0); -webkit-mask-composite: xor; mask-composite: exclude; opacity: 0; transition: opacity 0.28s ease; pointer-events: none; }
  .cat-card:hover { transform: translateY(-5px); border-color: transparent; box-shadow: 0 14px 34px rgba(0,0,0,0.5), 0 0 26px var(--glow-bronze, rgba(201,162,90,0.22)); }
  .cat-card:hover .cat-glow { opacity: 1; }
  .cat-card:hover::after { opacity: 0.12; transform: translateY(-4px) rotate(-4deg); }
  .cat-icon { display: inline-flex; margin-bottom: 0.9rem; color: var(--color-bronze); transition: color 0.28s ease, filter 0.28s ease; }
  .cat-card:hover .cat-icon { color: var(--color-bronze-bright, #e6c988); filter: drop-shadow(0 0 10px var(--glow-bronze, rgba(201,162,90,0.5))); }
  .cat-card svg { display: block; }
  .cat-card h3 { font-family: var(--font-title); font-size: 1.2rem; margin: 0 0 0.5rem; color: var(--color-parchment); }
  .cat-card p { font-size: 0.92rem; line-height: 1.55; margin: 0; }
  .cat-enter { position: absolute; top: 1.1rem; right: 1.2rem; font-family: var(--font-display, serif); font-size: 1.1rem; color: var(--color-bronze); opacity: 0; transform: translateX(-4px); transition: opacity 0.28s ease, transform 0.28s ease; }
  .cat-card:hover .cat-enter { opacity: 0.8; transform: translateX(0); }

  .post-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.4rem; }

  /* ===== ARTIST CARDS — premium ===== */
  .artist-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.4rem; }
  .artist-card { position: relative; display: grid; grid-template-columns: 1fr 1fr; gap: 1.2rem; align-items: center; border: 1px solid var(--color-border); border-radius: var(--radius); padding: 1.5rem; background:
      radial-gradient(ellipse 90% 120% at 0% 0%, rgba(201,162,90,0.06), transparent 55%),
      linear-gradient(180deg, var(--color-bg-raised), var(--color-ink, #0c0a08)); transition: transform 0.28s ease, border-color 0.28s ease, box-shadow 0.28s ease; }
  .artist-card:hover { transform: translateY(-3px); border-color: var(--color-bronze-dim, rgba(201,162,90,0.5)); box-shadow: 0 12px 30px rgba(0,0,0,0.45), 0 0 24px var(--glow-bronze, rgba(201,162,90,0.18)); }
  .artist-info h3 { font-family: var(--font-display); font-size: 1.55rem; margin: 0 0 0.5rem; color: var(--color-bronze-bright); text-shadow: 0 0 18px var(--glow-bronze, rgba(201,162,90,0.25)); }
  .artist-info p { font-size: 0.95rem; margin: 0 0 1rem; }
  .artist-links { display: flex; gap: 0.6rem; }
  .artist-links .btn { padding: 0.5rem 1rem; font-size: 0.85rem; }
  .artist-card iframe { width: 100%; height: 152px; border-radius: var(--radius); }

  /* ===== NEWSLETTER — inviting, premium ===== */
  .newsletter { position: relative; text-align: center; padding: clamp(2.8rem, 7vw, 4.5rem) 2rem; border: 1px solid var(--color-border-strong); border-radius: var(--radius); background:
      radial-gradient(ellipse 80% 70% at 50% 0%, var(--glow-blood, rgba(160,44,28,0.16)), transparent 68%),
      radial-gradient(ellipse 60% 60% at 50% 120%, var(--color-aurora, rgba(64,148,140,0.10)), transparent 60%),
      linear-gradient(180deg, var(--color-bg-raised), var(--color-ink, #0c0a08)); overflow: hidden; box-shadow: 0 20px 50px rgba(0,0,0,0.4); }
  .newsletter-runes { position: absolute; top: -20px; right: 30px; font-size: 9rem; color: var(--color-bronze); opacity: 0.06; pointer-events: none; }
  .newsletter-glow { position: absolute; inset: 0; border-radius: var(--radius); padding: 1px; background: linear-gradient(135deg, var(--color-bronze), transparent 45%, transparent 55%, var(--color-blood, #a02c1c)); -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0); -webkit-mask-composite: xor; mask-composite: exclude; opacity: 0.35; pointer-events: none; }
  .newsletter > *:not(.newsletter-runes):not(.newsletter-glow) { position: relative; z-index: 1; }
  .newsletter h2 { font-size: clamp(1.8rem, 4vw, 2.6rem); margin: 0.4rem 0 1rem; }
  .newsletter-copy { max-width: 52ch; margin: 0 auto 1.8rem; }
  .newsletter-form { display: flex; gap: 0.7rem; max-width: 460px; margin: 0 auto; }
  .newsletter-form input { flex: 1; padding: 0.8rem 1rem; border-radius: var(--radius); border: 1px solid var(--color-border-strong); background: var(--color-void); color: var(--color-parchment); font-family: var(--font-body); font-size: 1rem; transition: border-color 0.2s ease, box-shadow 0.2s ease; }
  .newsletter-form input:focus { border-color: var(--color-bronze); outline: none; box-shadow: 0 0 0 3px var(--glow-bronze, rgba(201,162,90,0.18)); }
  .nl-done { margin-top: 1rem; font-style: italic; }

  @media (max-width: 900px) { .cat-grid { grid-template-columns: repeat(2, 1fr); } .post-grid { grid-template-columns: repeat(2, 1fr); } .artist-grid { grid-template-columns: 1fr; } }
  @media (max-width: 600px) {
    .hero { min-height: clamp(500px, 82vh, 720px); }
    .cat-grid { grid-template-columns: 1fr; }
    .post-grid { grid-template-columns: 1fr; }
    .artist-card { grid-template-columns: 1fr; }
    .newsletter-form { flex-direction: column; }
    .section-head.center .eyebrow.flourish::before,
    .section-head.center .eyebrow.flourish::after { display: none; }
    .hero-runes { letter-spacing: 0.5em; font-size: 1.1rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-bg { animation: none; transform: scale(1.04); }
    .hero-aurora { animation: none; }
    .hero-scroll-line { animation: none; }
  }
</style>
