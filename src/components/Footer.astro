---
import { useTranslations, localizedPath } from '../i18n/utils';
import { artists } from '../data/artists';
import type { Lang } from '../i18n/ui';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-shell">
    <div class="divider" aria-hidden="true">
      <span class="divider-line"></span>
      <svg viewBox="0 0 40 40" width="26" height="26">
        <path d="M20 3 L34 11 V29 L20 37 L6 29 V11 Z" fill="none" stroke="currentColor" stroke-width="1.2"/>
        <circle cx="20" cy="20" r="4" fill="none" stroke="currentColor" stroke-width="1.2"/>
      </svg>
      <span class="divider-line"></span>
    </div>

    <div class="footer-grid">
      <div>
        <p class="footer-brand">NORDWEG</p>
        <p class="text-dim footer-tagline">{t('footer.tagline')}</p>
      </div>
      <div>
        <h4 class="footer-head">{t('footer.discover')}</h4>
        <ul>
          <li><a href={localizedPath('/blog', lang)}>{t('footer.allArticles')}</a></li>
          <li><a href={localizedPath('/blog', lang) + '?cat=Mythologie'}>{t('nav.mythology')}</a></li>
          <li><a href={localizedPath('/blog', lang) + '?cat=Runen'}>{t('nav.runes')}</a></li>
          <li><a href={localizedPath('/artists', lang)}>{t('nav.artists')}</a></li>
        </ul>
      </div>
      <div>
        <h4 class="footer-head">{t('footer.follow')}</h4>
        <ul>
          <li><a href={artists.domsgard.spotifyUrl} target="_blank" rel="noopener">Domsgard · Spotify</a></li>
          <li><a href={artists.eldruna.spotifyUrl} target="_blank" rel="noopener">Eldruna · Spotify</a></li>
          <li><a href={artists.domsgard.youtubeUrl} target="_blank" rel="noopener">Domsgard · YouTube</a></li>
          <li><a href={artists.eldruna.youtubeUrl} target="_blank" rel="noopener">Eldruna · YouTube</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-base">
      <span class="footer-rune" aria-hidden="true">ᚾ ᛟ ᚱ ᛞ</span>
      <p class="footer-copy text-dim">© {year} Nordweg · {t('footer.copy')}</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    margin-top: 5rem;
    border-top: 1px solid var(--color-border);
    background: linear-gradient(180deg, transparent, rgba(0, 0, 0, 0.4));
    padding-bottom: 2.75rem;
    overflow: hidden;
  }
  /* firelight hairline mirroring the header */
  .site-footer::before {
    content: '';
    position: absolute;
    left: 0; right: 0; top: -1px;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(201, 162, 90, 0.3), transparent);
    pointer-events: none;
  }
  /* faint rune watermark bleeding up from the depths */
  .site-footer::after {
    content: 'ᚨ';
    position: absolute;
    right: 4%;
    bottom: -2.5rem;
    font-family: var(--font-display);
    font-size: 16rem;
    line-height: 1;
    color: var(--color-bronze);
    opacity: 0.03;
    pointer-events: none;
    user-select: none;
  }
  .footer-shell { position: relative; z-index: 1; }

  /* ---------- Divider with flanking hairlines ---------- */
  .divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    color: var(--color-bronze-dim);
    padding: 0.5rem 0 1.75rem;
  }
  .divider-line {
    height: 1px;
    flex: 1;
    max-width: 12rem;
    background: linear-gradient(90deg, transparent, var(--color-border-strong));
  }
  .divider-line:last-child {
    background: linear-gradient(90deg, var(--color-border-strong), transparent);
  }

  /* ---------- Grid ---------- */
  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    gap: 2.5rem;
    margin-top: 0.5rem;
  }
  .footer-brand {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.15rem;
    letter-spacing: 0.24em;
    color: var(--color-bronze);
    margin: 0 0 0.6rem;
    text-shadow: var(--glow-bronze);
  }
  .footer-tagline { margin: 0; max-width: 34ch; font-size: 0.95rem; line-height: 1.7; }
  .footer-head {
    font-family: var(--font-title);
    color: var(--color-parchment);
    font-size: 0.9rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin: 0 0 1rem;
    position: relative;
    padding-bottom: 0.6rem;
  }
  .footer-head::after {
    content: '';
    position: absolute;
    left: 0; bottom: 0;
    width: 1.75rem;
    height: 1.5px;
    background: linear-gradient(90deg, var(--color-bronze), transparent);
  }
  .footer-grid ul { list-style: none; padding: 0; margin: 0; }
  .footer-grid li { margin-bottom: 0.6rem; }
  .footer-grid a {
    color: var(--color-text-dim);
    font-size: 0.95rem;
    transition: color 0.25s ease, padding-left 0.25s ease;
  }
  .footer-grid a:hover {
    color: var(--color-bronze-bright);
    padding-left: 0.25rem;
  }

  /* ---------- Base row ---------- */
  .footer-base {
    margin-top: 3rem;
    text-align: center;
  }
  .footer-rune {
    display: block;
    font-family: var(--font-title);
    font-size: 0.9rem;
    letter-spacing: 0.75em;
    color: var(--color-bronze-dim);
    opacity: 0.5;
    margin-bottom: 1rem;
    /* letter-spacing pushes content right; nudge back to stay centered */
    padding-left: 0.75em;
  }
  .footer-copy {
    margin: 0;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
  }

  @media (max-width: 720px) {
    .footer-grid { grid-template-columns: 1fr; gap: 1.9rem; }
    .divider-line { max-width: 5rem; }
    .site-footer::after { font-size: 11rem; right: -1%; }
  }
</style>
