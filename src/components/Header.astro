---
import { useTranslations, localizedPath } from '../i18n/utils';
import type { Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
  altUrl?: string;
}
const { lang, altUrl } = Astro.props;
const t = useTranslations(lang);

const nav = [
  { href: localizedPath('/', lang), label: t('nav.home') },
  { href: localizedPath('/blog', lang), label: t('nav.blog') },
  { href: localizedPath('/blog', lang) + '?cat=Mythologie', label: t('nav.mythology') },
  { href: localizedPath('/blog', lang) + '?cat=Runen', label: t('nav.runes') },
  { href: localizedPath('/blog', lang) + '?cat=Rezepte', label: t('nav.recipes') },
  { href: lang === 'de' ? '/kochbuch' : '/en/cookbook', label: t('nav.cookbook') },
  { href: localizedPath('/artists', lang), label: t('nav.artists') },
];
const path = Astro.url.pathname;

// Ziel des Sprachumschalters: explizite altUrl, sonst Pfad in die andere Sprache spiegeln
const otherLang: Lang = lang === 'de' ? 'en' : 'de';
const currentClean = lang === 'de' ? path : path.replace(/^\/en/, '') || '/';
const switchHref = altUrl ?? localizedPath(currentClean, otherLang);
---

<header class="site-header">
  <div class="container header-inner">
    <a href={localizedPath('/', lang)} class="brand" aria-label="Nordweg">
      <span class="brand-mark">
        <svg viewBox="0 0 32 32" width="30" height="30" aria-hidden="true">
          <path d="M16 2 L28 9 V23 L16 30 L4 23 V9 Z" fill="none" stroke="currentColor" stroke-width="1.4"/>
          <path d="M16 8 L16 24 M16 8 L21 13 M16 16 L21 11 M16 16 L11 11 M16 8 L11 13" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
        </svg>
      </span>
      <span class="brand-name">NORDWEG</span>
    </a>

    <div class="header-right">
      <nav class="nav" aria-label="Navigation">
        {nav.map((item) => (
          <a href={item.href} class:list={['nav-link', { active: path === item.href }]}>
            <span>{item.label}</span>
          </a>
        ))}
      </nav>

      <span class="header-sep" aria-hidden="true"></span>

      <div class="lang-switch" role="group" aria-label={t('lang.switch')}>
        <svg class="lang-globe" viewBox="0 0 24 24" width="15" height="15" aria-hidden="true">
          <circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="1.4"/>
          <path d="M3 12 H21 M12 3 C15 6 15 18 12 21 C9 18 9 6 12 3" fill="none" stroke="currentColor" stroke-width="1.4"/>
        </svg>
        <div class="lang-pill">
          {lang === 'de' ? (
            <span class="lang-btn active" aria-current="true" lang="de">DE</span>
          ) : (
            <a href={switchHref} class="lang-btn" hreflang="de" lang="de">DE</a>
          )}
          {lang === 'en' ? (
            <span class="lang-btn active" aria-current="true" lang="en">EN</span>
          ) : (
            <a href={switchHref} class="lang-btn" hreflang="en" lang="en">EN</a>
          )}
        </div>
      </div>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(14px) saturate(1.1);
    -webkit-backdrop-filter: blur(14px) saturate(1.1);
    background: linear-gradient(180deg, rgba(12, 11, 9, 0.94), rgba(12, 11, 9, 0.74));
    border-bottom: 1px solid var(--color-border);
    box-shadow: 0 1px 0 rgba(201, 162, 90, 0.04), 0 10px 30px -20px rgba(0, 0, 0, 0.9);
  }
  /* hairline of firelight along the very bottom edge */
  .site-header::after {
    content: '';
    position: absolute;
    left: 0; right: 0; bottom: -1px;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(201, 162, 90, 0.35), transparent);
    opacity: 0.7;
    pointer-events: none;
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
    gap: 1rem;
  }

  /* ---------- Brand ---------- */
  .brand {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    color: var(--color-bronze);
    transition: color 0.3s ease;
  }
  .brand-mark {
    display: inline-flex;
    color: var(--color-bronze);
    transition: color 0.3s ease, filter 0.3s ease, transform 0.4s ease;
  }
  .brand:hover .brand-mark {
    color: var(--color-bronze-bright);
    filter: drop-shadow(var(--glow-bronze));
    transform: rotate(-4deg);
  }
  .brand-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.35rem;
    letter-spacing: 0.24em;
    color: var(--color-parchment);
    transition: text-shadow 0.3s ease, color 0.3s ease;
  }
  .brand:hover .brand-name {
    color: var(--color-bronze-bright);
    text-shadow: var(--glow-bronze);
  }

  /* ---------- Right cluster ---------- */
  .header-right { display: flex; align-items: center; gap: 1.35rem; }

  /* ---------- Nav ---------- */
  .nav { display: flex; gap: 1.75rem; }
  .nav-link {
    font-family: var(--font-title);
    letter-spacing: 0.1em;
    font-size: 0.95rem;
    color: var(--color-text-dim);
    position: relative;
    padding: 0.4rem 0.1rem;
    transition: color 0.25s ease;
  }
  .nav-link:hover, .nav-link.active { color: var(--color-parchment); }
  /* refined underline: grows from center, bronze with a soft aurora tip */
  .nav-link::after {
    content: '';
    position: absolute;
    left: 50%; right: 50%; bottom: -2px;
    height: 1.5px;
    background: linear-gradient(90deg, transparent, var(--color-bronze) 30%, var(--color-bronze) 70%, transparent);
    transition: left 0.3s ease, right 0.3s ease, opacity 0.3s ease;
    opacity: 0;
  }
  .nav-link:hover::after { left: 0; right: 0; opacity: 0.55; }
  .nav-link.active::after {
    left: 0; right: 0; opacity: 1;
    box-shadow: 0 0 8px rgba(201, 162, 90, 0.4);
  }

  /* ---------- Hairline separator between nav & switcher ---------- */
  .header-sep {
    width: 1px;
    height: 26px;
    background: linear-gradient(180deg, transparent, var(--color-border-strong), transparent);
  }

  /* ---------- Language switcher ---------- */
  .lang-switch {
    display: flex;
    align-items: center;
    gap: 0.55rem;
  }
  .lang-globe {
    color: var(--color-bronze-dim);
    flex-shrink: 0;
    transition: color 0.3s ease;
  }
  .lang-switch:hover .lang-globe { color: var(--color-bronze); }
  .lang-pill {
    display: inline-flex;
    align-items: center;
    padding: 3px;
    gap: 2px;
    border: 1px solid var(--color-border-strong);
    border-radius: 999px;
    background: rgba(10, 9, 8, 0.5);
    box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.4);
  }
  .lang-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.15rem;
    height: 1.7rem;
    padding: 0 0.15rem;
    border-radius: 999px;
    font-family: var(--font-title);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    color: var(--color-text-dim);
    transition: color 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
  }
  a.lang-btn:hover { color: var(--color-parchment); }
  .lang-btn.active {
    color: var(--color-ink);
    background: linear-gradient(180deg, var(--color-bronze-bright), var(--color-bronze));
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.35), var(--glow-bronze);
    font-weight: 600;
    cursor: default;
  }

  /* ---------- Responsive ---------- */
  /* Nav order: 1 Start · 2 Chronik · 3 Mythologie · 4 Runen · 5 Rezepte · 6 Artists.
     Rezepte (5) muss auf Mobile IMMER sichtbar bleiben (Kochbuch-Funnel) -
     stattdessen fliegen Mythologie/Runen (3, 4) raus. */
  @media (max-width: 820px) {
    .nav { gap: 1.2rem; font-size: 0.85rem; }
    .nav-link:nth-child(3), .nav-link:nth-child(4) { display: none; }
    .brand-name { font-size: 1.15rem; letter-spacing: 0.18em; }
    .header-right { gap: 1rem; }
  }
  @media (max-width: 520px) {
    .header-inner { height: 64px; }
    .nav-link:nth-child(1) { display: none; }
    .header-sep { height: 22px; }
    .lang-switch { gap: 0.4rem; }
    /* keep the pill neat & legible, never cramped */
    .lang-btn { min-width: 2rem; height: 1.65rem; font-size: 0.76rem; }
  }
  @media (max-width: 400px) {
    .header-right { gap: 0.7rem; }
    .nav { gap: 0.95rem; }
    /* tightest screens: drop Artists (6) too - Chronik + Rezepte bleiben */
    .nav-link:nth-child(7) { display: none; }
    /* hide the globe on the tightest screens so the pill keeps its breathing room */
    .lang-globe { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .brand, .brand-mark, .brand-name, .nav-link, .nav-link::after,
    .lang-globe, .lang-btn {
      transition: none;
    }
    .brand:hover .brand-mark { transform: none; }
  }
</style>
