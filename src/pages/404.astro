---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 - Seite nicht gefunden"
  description="Diese Seite existiert nicht. Diese Saga wurde noch nicht geschrieben."
  lang="de"
>
  <section class="container notfound">
    <span class="nf-rune" aria-hidden="true">ᚨ</span>

    <div class="nf-content">
      <p class="eyebrow">404 · Verirrt im Nebel</p>
      <h1 class="nf-title">Diese Saga wurde noch nicht geschrieben.</h1>
      <p class="nf-en text-dim" lang="en">This saga has not been written yet.</p>

      <div class="nf-actions">
        <a class="btn btn--primary" href="/blog">Zur Chronik</a>
        <a class="btn" href="/">Zur Startseite</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .notfound {
    position: relative;
    min-height: 62vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding-top: 4rem;
    padding-bottom: 4rem;
    overflow: hidden;
  }

  /* Riesige Rune als Wasserzeichen hinter dem Text */
  .nf-rune {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -52%);
    font-family: var(--font-display);
    font-size: clamp(16rem, 46vw, 30rem);
    line-height: 1;
    color: var(--color-bronze);
    opacity: 0.05;
    text-shadow: var(--glow-bronze);
    pointer-events: none;
    user-select: none;
  }

  .nf-content {
    position: relative;
    z-index: 1;
    max-width: 42rem;
  }
  .nf-title {
    font-size: clamp(1.7rem, 5.5vw, 2.9rem);
    margin: 0.9rem 0 0.8rem;
    text-shadow: var(--glow-bronze);
  }
  .nf-en {
    font-style: italic;
    font-size: 1.05rem;
    margin: 0 0 2.2rem;
  }
  .nf-actions {
    display: flex;
    gap: 0.9rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 640px) {
    .notfound { min-height: 55vh; }
    .nf-actions .btn { padding: 0.7rem 1.3rem; }
  }
</style>
